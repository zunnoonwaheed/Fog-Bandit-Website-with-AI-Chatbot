{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/chat.ts": {
      "memory": 512,
      "maxDuration": 60
    },
    "api/leads.ts": {
      "memory": 256,
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/((?!api/.*).*)",
      "destination": "/index.html"
    }
  ]
}
